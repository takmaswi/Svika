# Supabase — get these from your Supabase project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Mapbox — get from account.mapbox.com. Public token, scope: styles:read,fonts:read,tiles:read
NEXT_PUBLIC_MAPBOX_TOKEN=pk.YOUR_PUBLIC_TOKEN
# Server-side Mapbox secret token. Used by the seed loader + sim runner to
# road-snap route polylines via the Directions API. Issue at
# account.mapbox.com with scope: directions:read (no URL restrictions).
# Optional — densification silently falls back to the public token (if
# scoped) and ultimately to raw seed polylines.
MAPBOX_SECRET_TOKEN=sk.YOUR_SECRET_TOKEN

# Local AI (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b-it-q4_K_M

# Cloud AI fallback (Google Generative AI)
GEMINI_API_KEY=YOUR_GEMINI_KEY
GEMINI_MODEL=gemini-2.5-flash

# Per-job provider selection (Plan B per docs/PHASE-0-GEMMA-SPIKE.md):
#   understand() → Gemini (sub-second, drives the live search bar)
#   narrate()    → Ollama Gemma (on-device, async audit narrative)
# AI_PROVIDER is a global fallback used when the per-job vars are unset.
UNDERSTAND_PROVIDER=gemini
NARRATE_PROVIDER=ollama
AI_PROVIDER=ollama

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
